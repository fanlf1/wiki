  "_说明": "投资机构信息完善状态跟踪。completeness: X/7 (完成模块数/总模块数)。evidence_tier: S/A/B/C。update_status: 待更新/进行中/已完成。modules: 各模块完成度(true/false)。",
  "_completeness等级": {
    "7/7 ★": "完整：所有模块已完成，含深度调研",
    "5-6/7": "充实：核心模块完成，缺exits或depth",
    "3-4/7": "初步：基本信息+部分模块",
    "1-2/7": "骨架：仅基本信息或极少数模块"
  },
  "_update_status定义": {
    "待更新": "需要补充，尚未认领",
    "进行中": "已被agent认领，正在调研",
    "已完成": "本次无需更新或已更新完毕"
  },
  "_模块定义": {
    "info": "基本信息（规模、类型、总部、阶段偏好）",
