    "gp": "关键合伙人（姓名、方向、背景、代表投资）",
    "thesis": "投资逻辑/论文（公开的投资哲学和观点）",
    "exits": "退出记录（IPO/收购/关闭）",
    "signal": "值得关注的信号（最新动态、观点变化）",
    "depth": "深度调研（完整6模块调研，对应.skill方法论）"
  },
  "evidence_tier定义": {
    "S": "风向标：投资即信号，方向高度预测赛道趋势",
    "A": "产业验证：投资反映产业链战略判断",
    "B": "补充信号：有参考价值，辅助验证",
    "C": "背景参考：了解行业格局，不直接驱动决策"
  },
